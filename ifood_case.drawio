        </mxCell>
        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-40" parent="1" style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;rounded=0;fillColor=#f5f5f5;fontColor=#333333;strokeColor=none;" value="YAML defined:&lt;div&gt;- Global Settings: S3 Information (bucket name and s3 key prefixes)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- Dataset settings:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;- dataset name&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;- nyc tlc endpoint template&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;- rules to silver layer data promotion&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;- gold layer definitions (marts):&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - mart name&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - table name&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="230" x="60" y="583" as="geometry" />
        </mxCell>
        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-43" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div&gt;&lt;b&gt;global_settings&lt;/b&gt;:&lt;/div&gt;&lt;div&gt;&amp;nbsp; s3_bucket: &quot;ifood-case-lucas-datalake-762131618299-us-east-2-an&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; s3_raw_prefix: &quot;raw/nyc_tlc&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; s3_bronze_prefix: &quot;bronze/nyc_tlc&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; s3_silver_prefix: &quot;silver/nyc_tlc&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; s3_gold_prefix: &quot;gold/nyc_tlc&quot;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;datasets:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; - name: &quot;yellow&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; endpoint_template: &quot;trip-data/yellow_tripdata_{{ logical_date.strftime(&#39;%Y-%m&#39;) }}.parquet&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; silver_rule: &quot;nyc_yellow_taxi&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; marts:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - name: &quot;monthly_revenue&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; table_name: &quot;default.gold_nyc_tlc_monthly_revenue&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - name: &quot;hourly_passengers&quot;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; table_name: &quot;default.gold_nyc_tlc_hourly_passengers&quot;&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="520" x="310" y="593" as="geometry" />
        </mxCell>
        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-44" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="Three types of jobs deployed:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;- Raw to Bronze&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;i&gt;&amp;nbsp; &amp;nbsp;- Parameters:&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - dataset_name&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - raw_path&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - bronze_path&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - bronze_table_name&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - partition_keys&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - partition_values&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="180" x="290" y="90" as="geometry" />
        </mxCell>
        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-48" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div&gt;&lt;b&gt;- Silver to Gold&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;i&gt;&amp;nbsp; &amp;nbsp;- Parameters:&amp;nbsp;&lt;/i&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - mart_name&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - silver_path&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - gold_path&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - gold_table_name&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - partition_keys&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - partition_values&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="203" x="605" y="116" as="geometry" />
        </mxCell>
        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-49" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontStyle=1;fontSize=24;" value="iFood Data Engineering Case" vertex="1">
          <mxGeometry height="30" width="600" x="10" y="10" as="geometry" />
