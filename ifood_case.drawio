        <mxCell id="_9hCIqOi5AIZX8ZJjxoT-50" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontStyle=1;fontSize=24;" value="&lt;font style=&quot;font-size: 18px; font-weight: normal;&quot;&gt;Lucas Ramos&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="600" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="0H3Kjc0kfo9VD9Zy5zOo-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="O que poderia melhorar:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;a) Promoções silver e gold definidas por SQL&lt;/div&gt;&lt;div&gt;b) Repositório de schemas para definir as tabelas, não aceitar schema do primeiro arquivo&lt;/div&gt;&lt;div&gt;c) Dag factory&lt;/div&gt;&lt;div&gt;d) Processo de backfill: downloads podem até ser sequenciais, mas leitura e promoção deveria ser em bulk&lt;/div&gt;" vertex="1">
